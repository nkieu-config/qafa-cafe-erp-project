# Connect to Postgres via the shared transaction-mode pooler
DATABASE_URL="postgresql://user:password@host:6543/dbname?pgbouncer=true"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# JWT Secret - MUST be set. Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Allowed CORS origins (comma-separated)
CORS_ORIGIN="http://localhost:3001"

# Demo seed is destructive. Localhost databases can seed without these flags.
# Remote demo/staging databases require both values:
# ALLOW_DEMO_SEED=true
# DEMO_SEED_CONFIRM=WIPE_DEMO_DATABASE
