generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(STAFF)
  branchId  Int?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  hourlyRate Float   @default(0)
  orders    Order[]
  transfersRequested StockTransfer[] @relation("TransferRequestedBy")
  transfersApproved  StockTransfer[] @relation("TransferApprovedBy")
  auditLogs AuditLog[]
  shifts    Shift[]
  attendanceRecords AttendanceRecord[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  MANAGER
  STAFF
}

model Branch {
  id             Int               @id @default(autoincrement())
  name           String
  location       String?
  users          User[]
  orders         Order[]
  inventories    BranchInventory[]
  purchaseOrders PurchaseOrder[]
  inventoryBatches InventoryBatch[]
  transfersOut   StockTransfer[]   @relation("TransferFrom")
  transfersIn    StockTransfer[]   @relation("TransferTo")
  shifts         Shift[]
  attendanceRecords AttendanceRecord[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model Ingredient {
  id                 Int                 @id @default(autoincrement())
  name               String
  unit               String
  globalMinStock     Int                 @default(0)
  recipeItems        RecipeItem[]
  branchInventories  BranchInventory[]
  purchaseOrderItems PurchaseOrderItem[]
  inventoryBatches   InventoryBatch[]
  stockTransfers     StockTransfer[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model BranchInventory {
  id           Int        @id @default(autoincrement())
  branchId     Int
  branch       Branch     @relation(fields: [branchId], references: [id])
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  stock        Float      @default(0)
  minStock     Float      @default(0)
  updatedAt    DateTime   @updatedAt

  @@unique([branchId, ingredientId])
}

model InventoryBatch {
  id           Int        @id @default(autoincrement())
  branchId     Int
  branch       Branch     @relation(fields: [branchId], references: [id])
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float
  expiryDate   DateTime?
  poId         Int?
  purchaseOrder PurchaseOrder? @relation(fields: [poId], references: [id])
  status       BatchStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum BatchStatus {
  ACTIVE
  DEPLETED
  EXPIRED
}

model StockTransfer {
  id              Int        @id @default(autoincrement())
  fromBranchId    Int
  fromBranch      Branch     @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranchId      Int
  toBranch        Branch     @relation("TransferTo", fields: [toBranchId], references: [id])
  ingredientId    Int
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id])
  quantity        Float
  status          TransferStatus @default(PENDING)
  requestedById   Int
  requestedBy     User       @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  approvedById    Int?
  approvedBy      User?      @relation("TransferApprovedBy", fields: [approvedById], references: [id])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

enum TransferStatus {
  PENDING
  SHIPPED
  COMPLETED
  CANCELLED
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  action      String
  targetType  String   // e.g. "InventoryBatch", "Order", "StockTransfer"
  targetId    Int?
  details     String?  // JSON string or text details
  createdAt   DateTime @default(now())
}

model Product {
  id          Int          @id @default(autoincrement())
  name        String
  price       Float
  category    String
  recipeItems RecipeItem[]
  orderItems  OrderItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model RecipeItem {
  id           Int        @id @default(autoincrement())
  productId    Int
  product      Product    @relation(fields: [productId], references: [id])
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float
}

model Customer {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  name      String
  points    Int      @default(0)
  tier      Tier     @default(REGULAR)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Tier {
  REGULAR
  SILVER
  GOLD
  PLATINUM
}

model Promotion {
  id            Int          @id @default(autoincrement())
  code          String       @unique
  description   String
  discountType  DiscountType
  discountValue Float
  minPurchase   Float?
  isActive      Boolean      @default(true)
  startDate     DateTime?
  endDate       DateTime?
  orders        Order[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Order {
  id             Int         @id @default(autoincrement())
  totalAmount    Float
  discountAmount Float       @default(0)
  netAmount      Float       @default(0)
  pointsEarned   Int         @default(0)
  pointsRedeemed Int         @default(0)
  userId         Int
  user           User        @relation(fields: [userId], references: [id])
  branchId       Int
  branch         Branch      @relation(fields: [branchId], references: [id])
  customerId     Int?
  customer       Customer?   @relation(fields: [customerId], references: [id])
  promotionId    Int?
  promotion      Promotion?  @relation(fields: [promotionId], references: [id])
  items          OrderItem[]
  createdAt      DateTime    @default(now())
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model Supplier {
  id             Int             @id @default(autoincrement())
  name           String
  contactEmail   String?
  phone          String?
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PurchaseOrder {
  id         Int                 @id @default(autoincrement())
  poNumber   String              @unique
  branchId   Int
  branch     Branch              @relation(fields: [branchId], references: [id])
  supplierId Int
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  status     POStatus            @default(PENDING)
  items      PurchaseOrderItem[]
  inventoryBatches InventoryBatch[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
}

enum POStatus {
  DRAFT
  PENDING
  APPROVED
  RECEIVED
}

model PurchaseOrderItem {
  id                Int           @id @default(autoincrement())
  poId              Int
  purchaseOrder     PurchaseOrder @relation(fields: [poId], references: [id])
  ingredientId      Int
  ingredient        Ingredient    @relation(fields: [ingredientId], references: [id])
  quantityRequested Float
  unitPrice         Float
}

model Shift {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id])
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AttendanceRecord {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  branchId   Int
  branch     Branch   @relation(fields: [branchId], references: [id])
  clockIn    DateTime @default(now())
  clockOut   DateTime?
  totalHours Float?   // Calculated on clock out
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
