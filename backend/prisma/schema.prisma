generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(STAFF)
  employmentType EmploymentType @default(PART_TIME)
  branchId  Int?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  hourlyRate Float   @default(0)
  baseSalary Float   @default(0)
  orders    Order[]
  transfersRequested StockTransfer[] @relation("TransferRequestedBy")
  transfersApproved  StockTransfer[] @relation("TransferApprovedBy")
  auditLogs AuditLog[]
  shifts    Shift[]
  attendanceRecords AttendanceRecord[]
  leaveRequests     LeaveRequest[]
  wasteLogs         WasteLog[]
  expenses          Expense[]
  shiftSettlements  ShiftSettlement[]
  payslips          Payslip[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  MANAGER
  STAFF
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
}

model Branch {
  id             Int               @id @default(autoincrement())
  name           String
  location       String?
  users          User[]
  orders         Order[]
  inventories    BranchInventory[]
  purchaseOrders PurchaseOrder[]
  inventoryBatches InventoryBatch[]
  transfersOut   StockTransfer[]   @relation("TransferFrom")
  transfersIn    StockTransfer[]   @relation("TransferTo")
  shifts         Shift[]
  attendanceRecords AttendanceRecord[]
  wasteLogs         WasteLog[]
  expenses          Expense[]
  shiftSettlements  ShiftSettlement[]
  payrollRuns       PayrollRun[]
  equipment         Equipment[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model Ingredient {
  id                 Int                 @id @default(autoincrement())
  name               String
  unit               String
  costPerUnit        Float               @default(0)
  primarySupplierId  Int?
  primarySupplier    Supplier?           @relation(fields: [primarySupplierId], references: [id])
  recipeItems        RecipeItem[]
  branchInventories  BranchInventory[]
  purchaseOrderItems PurchaseOrderItem[]
  inventoryBatches   InventoryBatch[]
  stockTransfers     StockTransfer[]
  wasteLogs          WasteLog[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model BranchInventory {
  id           Int        @id @default(autoincrement())
  branchId     Int
  branch       Branch     @relation(fields: [branchId], references: [id])
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  stock        Float      @default(0)
  minStock     Int
  updatedAt    DateTime   @updatedAt

  @@unique([branchId, ingredientId])
  @@index([branchId])
}

model InventoryBatch {
  id           Int        @id @default(autoincrement())
  branchId     Int
  branch       Branch     @relation(fields: [branchId], references: [id])
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float
  expiryDate   DateTime?
  poId         Int?
  purchaseOrder PurchaseOrder? @relation(fields: [poId], references: [id])
  status       BatchStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([branchId, ingredientId, status])
  @@index([expiryDate])
}

enum BatchStatus {
  ACTIVE
  DEPLETED
  EXPIRED
}

model StockTransfer {
  id              Int        @id @default(autoincrement())
  fromBranchId    Int
  fromBranch      Branch     @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranchId      Int
  toBranch        Branch     @relation("TransferTo", fields: [toBranchId], references: [id])
  ingredientId    Int
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id])
  quantity        Float
  status          TransferStatus @default(PENDING)
  requestedById   Int
  requestedBy     User       @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  approvedById    Int?
  approvedBy      User?      @relation("TransferApprovedBy", fields: [approvedById], references: [id])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([status])
}

enum TransferStatus {
  PENDING
  SHIPPED
  COMPLETED
  CANCELLED
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  action      String
  targetType  String   // e.g. "InventoryBatch", "Order", "StockTransfer"
  targetId    Int?
  details     String?  // JSON string or text details
  createdAt   DateTime @default(now())
}

model Product {
  id          Int          @id @default(autoincrement())
  name        String
  price       Float
  category    String
  recipeItems RecipeItem[]
  orderItems  OrderItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model RecipeItem {
  id           Int        @id @default(autoincrement())
  productId    Int
  product      Product    @relation(fields: [productId], references: [id])
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float
}

model Customer {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  name      String
  points    Int      @default(0)
  tier      Tier     @default(REGULAR)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Tier {
  REGULAR
  SILVER
  GOLD
  PLATINUM
}

model Promotion {
  id            Int          @id @default(autoincrement())
  code          String       @unique
  description   String
  discountType  DiscountType
  discountValue Float
  minPurchase   Float?
  isActive      Boolean      @default(true)
  startDate     DateTime?
  endDate       DateTime?
  orders        Order[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  QR_PROMPTPAY
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum OrderStatus {
  PENDING
  PREPARING
  COMPLETED
  CANCELLED
}

model Order {
  id             Int         @id @default(autoincrement())
  totalAmount    Float
  discountAmount Float       @default(0)
  netAmount      Float       @default(0)
  taxAmount      Float       @default(0)
  totalCogs      Float       @default(0)
  pointsEarned   Int         @default(0)
  pointsRedeemed Int         @default(0)
  status         OrderStatus @default(PENDING)
  paymentMethod  PaymentMethod @default(CASH)
  isTaxInvoiceRequested Boolean @default(false)
  taxInvoiceName String?
  taxInvoiceTaxId String?
  taxInvoiceAddress String?
  userId         Int
  user           User        @relation(fields: [userId], references: [id])
  branchId       Int
  branch         Branch      @relation(fields: [branchId], references: [id])
  customerId     Int?
  customer       Customer?   @relation(fields: [customerId], references: [id])
  promotionId    Int?
  promotion      Promotion?  @relation(fields: [promotionId], references: [id])
  items          OrderItem[]
  createdAt      DateTime    @default(now())

  @@index([branchId])
  @@index([userId])
  @@index([createdAt])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float

  @@index([orderId])
  @@index([productId])
}

model Supplier {
  id             Int             @id @default(autoincrement())
  name           String
  contactEmail   String?
  phone          String?
  purchaseOrders PurchaseOrder[]
  ingredients    Ingredient[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PurchaseOrder {
  id         Int                 @id @default(autoincrement())
  poNumber   String              @unique
  branchId   Int
  branch     Branch              @relation(fields: [branchId], references: [id])
  supplierId Int
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  status     POStatus            @default(PENDING)
  isAutoGenerated Boolean        @default(false)
  items      PurchaseOrderItem[]
  inventoryBatches InventoryBatch[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
}

enum POStatus {
  DRAFT
  PENDING
  APPROVED
  RECEIVED
}

model PurchaseOrderItem {
  id                Int           @id @default(autoincrement())
  poId              Int
  purchaseOrder     PurchaseOrder @relation(fields: [poId], references: [id])
  ingredientId      Int
  ingredient        Ingredient    @relation(fields: [ingredientId], references: [id])
  quantityRequested Float
  unitPrice         Float
}

model Shift {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id])
  startTime DateTime
  endTime   DateTime
  status    ShiftStatus @default(SCHEDULED)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([userId])
}

enum ShiftStatus {
  SCHEDULED
  COMPLETED
  ABSENT
  CANCELLED
}

model LeaveRequest {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  type      LeaveType
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  reason    String?
  status    LeaveStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum LeaveType {
  SICK
  ANNUAL
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model AttendanceRecord {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  branchId   Int
  branch     Branch   @relation(fields: [branchId], references: [id])
  clockIn    DateTime @default(now())
  clockOut   DateTime?
  totalHours Float?   // Calculated on clock out
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WasteLog {
  id           Int        @id @default(autoincrement())
  branchId     Int
  branch       Branch     @relation(fields: [branchId], references: [id])
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Float
  reason       String
  recordedById Int
  recordedBy   User       @relation(fields: [recordedById], references: [id])
  createdAt    DateTime   @default(now())

  @@index([branchId])
  @@index([createdAt])
}

model Expense {
  id           Int      @id @default(autoincrement())
  branchId     Int
  branch       Branch   @relation(fields: [branchId], references: [id])
  amount       Float
  category     String
  description  String?
  recordedById Int
  recordedBy   User     @relation(fields: [recordedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([branchId])
  @@index([createdAt])
}

model ShiftSettlement {
  id            Int      @id @default(autoincrement())
  branchId      Int
  branch        Branch   @relation(fields: [branchId], references: [id])
  date          DateTime @default(now()) @db.Date
  expectedCash  Float    @default(0)
  actualCash    Float    @default(0)
  expectedCreditCard Float @default(0)
  actualCreditCard Float @default(0)
  expectedQR    Float    @default(0)
  actualQR      Float    @default(0)
  difference    Float    @default(0)
  status        SettlementStatus @default(PENDING)
  submittedById Int
  submittedBy   User     @relation(fields: [submittedById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum SettlementStatus {
  PENDING
  APPROVED
  REJECTED
}

model PayrollRun {
  id          Int      @id @default(autoincrement())
  month       Int
  year        Int
  status      PayrollStatus @default(DRAFT)
  branchId    Int?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  payslips    Payslip[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

model Payslip {
  id             Int        @id @default(autoincrement())
  payrollRunId   Int
  payrollRun     PayrollRun @relation(fields: [payrollRunId], references: [id])
  userId         Int
  user           User       @relation(fields: [userId], references: [id])
  standardHours  Float      @default(0)
  otHours        Float      @default(0)
  basePay        Float      @default(0)
  otPay          Float      @default(0)
  bonuses        Float      @default(0)
  grossPay       Float      @default(0)
  taxDeduction   Float      @default(0)
  socialSecurity Float      @default(0)
  otherDeductions Float     @default(0)
  netPay         Float      @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Equipment {
  id                  Int               @id @default(autoincrement())
  branchId            Int
  branch              Branch            @relation(fields: [branchId], references: [id])
  name                String
  type                EquipmentType
  serialNumber        String?
  status              EquipmentStatus   @default(ACTIVE)
  purchaseDate        DateTime?
  warrantyExpiry      DateTime?
  nextMaintenanceDate DateTime?
  maintenanceLogs     MaintenanceLog[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

enum EquipmentType {
  ESPRESSO_MACHINE
  GRINDER
  BLENDER
  POS_SYSTEM
  REFRIGERATOR
  OTHER
}

enum EquipmentStatus {
  ACTIVE
  MAINTENANCE
  BROKEN
  RETIRED
}

model MaintenanceLog {
  id              Int       @id @default(autoincrement())
  equipmentId     Int
  equipment       Equipment @relation(fields: [equipmentId], references: [id])
  description     String
  cost            Float     @default(0)
  performedBy     String?   // External technician or internal staff name
  date            DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
