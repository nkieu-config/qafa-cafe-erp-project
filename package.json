{
  "name": "erp",
  "version": "1.0.0",
  "description": "Enterprise ERP Root",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev:backend": "npm run start:dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx}": [
      "bash -c 'npm run type-check --prefix frontend'"
    ],
    "backend/**/*.ts": [
      "bash -c 'npm run type-check --prefix backend'"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3"
  },
  "workspaces": [
    "frontend",
    "backend"
  ]
}
